# local data
data/raw/

# refinery outputs (ignore everything)
.refinery/**

# allow folders so Git can reach the files
!.refinery/
!.refinery/profiles/

# allow only the interim-required artifacts
!.refinery/profiles/*.json
!.refinery/extraction_ledger.jsonl

# keep extracted outputs ignored (not required / can be big)
.refinery/extracted/
# temp files
*.swp

# python build artifacts
*.egg-info/

# stray local files
strategy
# caches / build
__pycache__/
*.pyc
*.pyo
*.egg-info/

# editor temp
*.swp

# local stray
strategy
# Python
.venv/
__pycache__/
*.pyc

# Environment variables
.env

# Data (optional if dataset is large)
data/

# Node (for later React UI)
node_modules/
dist/